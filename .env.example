# Copy to .env and fill in your values
# .env is gitignored — never committed

# NetBird setup key (from NetBird dashboard → Setup Keys)
NETBIRD_SETUP_KEY=

# WiFi hotspot password (manual override, default: derived from IMEI via HMAC)
WIFI_PASSWORD=

# Shared secret for WiFi PSK derivation (HMAC-SHA256)
# Same key must be on all OpenSticks and KiBu devices
# Get from: secrets/openstick-wifi.key in ha-operating-system repo
OPENSTICK_WIFI_SECRET=

# Root password for SSH
ROOT_PASSWORD=
